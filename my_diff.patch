+int ISR_VECT lr1121::currentRssi() {
+  uint8_t byte = 0;
+  executeOpcodeRead(OP_CURRENT_RSSI_6X, &byte, 1);
+  int rssi = -(int(byte)) / 2;
+  #if HAS_LORA_LNA
+    rssi -= LORA_LNA_GAIN;
+  #endif
+  return rssi;
+}
