+int ISR_VECT lr1121::packetRssi() {
+  uint8_t buf[3] = {0};
+  executeOpcodeRead(OP_PACKET_STATUS_6X, buf, 3);
+  int pkt_rssi = -buf[0] / 2;
+  #if HAS_LORA_LNA
+    pkt_rssi -= LORA_LNA_GAIN;
+  #endif
+  return pkt_rssi;
+}
